# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
indent_style = tab

# PHP
[*.php]
indent_style = tab

# JavaScript
[*.js]
indent_style = tab

# CSS
[*.css]
indent_style = tab

# YAML
[*.yml]
indent_style = space
indent_size = 4

# JSON
[*.json]
indent_style = space
indent_size = 4

# SASS
[*.scss]
indent_style = tab
